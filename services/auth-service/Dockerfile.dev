FROM node:20-alpine

# Install pnpm globally
RUN npm install -g pnpm

WORKDIR /app

# 1. Copy workspace configuration and root package.json
# These are required for pnpm to recognize the monorepo structure
COPY pnpm-lock.yaml pnpm-workspace.yaml package.json ./

# 2. Copy all package.json files from the entire monorepo 
COPY packages/api-contracts/package.json ./packages/api-contracts/
COPY packages/common/package.json ./packages/common/
COPY packages/config/package.json ./packages/config/
COPY packages/database/package.json ./packages/database/
COPY packages/image-storage/package.json ./packages/image-storage/
COPY packages/logger/package.json ./packages/logger/
COPY packages/rabbitmq/package.json ./packages/rabbitmq/
COPY packages/types/package.json ./packages/types/

COPY services/auth-service/package.json ./services/auth-service/
COPY services/chat-service/package.json ./services/chat-service/
COPY services/email-service/package.json ./services/email-service/
COPY services/order-service/package.json ./services/order-service/
COPY services/payment-service/package.json ./services/payment-service/
COPY services/product-service/package.json ./services/product-service/

# 3. Install dependencies
# We use --no-frozen-lockfile in dev to handle minor version mismatches 
# caused by the container's Linux environment vs your Windows host.
RUN pnpm install --no-frozen-lockfile --shamefully-hoist

# 3. Copy the source code for the shared packages
COPY packages/ ./packages/

# 4. Set the working directory to the specific service
WORKDIR /app/services/auth-service
# Note: We don't COPY the service source because it's handled by Docker Volumes in dev


EXPOSE 4001

# Use pnpm run dev to trigger your 'tsx watch' script
CMD ["pnpm", "--filter", "@repo/auth-service", "dev"]
