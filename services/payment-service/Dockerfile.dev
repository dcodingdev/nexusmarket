# ---------- 1. DEPS STAGE ----------
FROM node:20-alpine AS deps
WORKDIR /app
RUN npm install -g pnpm

COPY pnpm-lock.yaml pnpm-workspace.yaml turbo.json ./
COPY package.json ./
COPY packages/api-contracts/package.json ./packages/api-contracts/
COPY packages/common/package.json ./packages/common/
COPY packages/config/package.json ./packages/config/
COPY packages/database/package.json ./packages/database/
COPY packages/logger/package.json ./packages/logger/
COPY packages/rabbitmq/package.json ./packages/rabbitmq/
COPY packages/types/package.json ./packages/types/
COPY services/payment-service/package.json ./services/payment-service/

RUN pnpm install --filter @repo/payment-service... --frozen-lockfile

RUN mkdir -p \
    /app/packages/api-contracts/node_modules \
    /app/packages/common/node_modules \
    /app/packages/config/node_modules \
    /app/packages/database/node_modules \
    /app/packages/logger/node_modules \
    /app/packages/rabbitmq/node_modules \
    /app/packages/types/node_modules \
    /app/services/payment-service/node_modules

# ---------- 2. DEV RUNNER ----------
FROM node:20-alpine
WORKDIR /app
RUN npm install -g pnpm tsx

COPY --from=deps /app/node_modules ./node_modules
COPY --from=deps /app/packages/api-contracts/node_modules ./packages/api-contracts/node_modules
COPY --from=deps /app/packages/common/node_modules ./packages/common/node_modules
COPY --from=deps /app/packages/config/node_modules ./packages/config/node_modules
COPY --from=deps /app/packages/database/node_modules ./packages/database/node_modules
COPY --from=deps /app/packages/logger/node_modules ./packages/logger/node_modules
COPY --from=deps /app/packages/rabbitmq/node_modules ./packages/rabbitmq/node_modules
COPY --from=deps /app/packages/types/node_modules ./packages/types/node_modules
COPY --from=deps /app/services/payment-service/node_modules ./services/payment-service/node_modules

CMD ["pnpm", "--filter", "@repo/payment-service", "run", "dev"]
